# Copy to .env and fill in. Never commit .env.

# Groq API key for the Stage 2 LLM transform (https://console.groq.com/keys)
GROQ_API_KEY=

# Model used for structuring + concept extraction
DRIVEBOOK_LLM_MODEL=llama-3.3-70b-versatile

# Paths (defaults are fine for local dev)
DRIVEBOOK_DATA_DIR=data

# Key-frame extraction: scene-change sensitivity (0-1, higher = fewer frames)
DRIVEBOOK_FRAME_DIFF_THRESHOLD=0.45

# LatticeRAG walk: restart probability c (0-1) and combine weights
DRIVEBOOK_PPR_RESTART=0.5
